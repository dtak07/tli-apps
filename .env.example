# Geotab — use a read-only service account created in MyGeotab Admin
GEOTAB_SERVER=my.geotab.com
GEOTAB_DATABASE=your_database_name
GEOTAB_USERNAME=timecard-service@yourdomain.com
GEOTAB_PASSWORD=your_password_here

# Supabase — use the service_role key (not the anon key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Never commit the real .env file to git
